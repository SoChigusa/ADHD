rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsProfile(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read, write: if ownsProfile(userId);
    }

    match /publicProfiles/{shareId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.shareId == shareId;

      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.shareId == shareId;

      allow delete: if isSignedIn()
        && resource.data.userId == request.auth.uid;

      match /whispers/{whisperId} {
        allow read: if true;

        allow create: if isSignedIn()
          && get(/databases/$(database)/documents/publicProfiles/$(shareId)).data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 140;

        allow update: if isSignedIn()
          && get(/databases/$(database)/documents/publicProfiles/$(shareId)).data.userId == request.auth.uid
          && resource.data.userId == request.auth.uid
          && request.resource.data.userId == request.auth.uid
          && request.resource.data.text is string
          && request.resource.data.text.size() > 0
          && request.resource.data.text.size() <= 140;

        allow delete: if isSignedIn()
          && get(/databases/$(database)/documents/publicProfiles/$(shareId)).data.userId == request.auth.uid
          && resource.data.userId == request.auth.uid;
      }
    }
  }
}
